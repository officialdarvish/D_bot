# D Bot environment example
# Copy this file to .env and replace every CHANGE_ME value before running.

BOT_TOKEN=CHANGE_ME_BOT_TOKEN
OWNER_IDS=123456789
ADMIN_IDS=
SELLER_IDS=

DATABASE_URL=postgresql+asyncpg://dbot:CHANGE_ME_DB_PASSWORD@db:5432/d_bot
POSTGRES_DB=d_bot
POSTGRES_USER=dbot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
REDIS_URL=redis://redis:6379/0

API_HOST=0.0.0.0
API_PORT=8000
TZ=Asia/Tehran
DEFAULT_CHANNEL_URL=https://t.me/example
SERVER_SYNC_SECONDS=5

WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
JWT_SECRET=CHANGE_ME_JWT_SECRET
FERNET_KEY=CHANGE_ME_FERNET_KEY

NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=trx
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_IPN_CALLBACK_URL=

XUI_VERIFY_TLS=true
XUI_CA_BUNDLE=

BACKUP_MAX_UPLOAD_BYTES=5242880
BACKUP_REQUIRE_SIGNATURE=true
BACKUP_SIGNING_SECRET=
DBOT_ALLOW_DOCKER_RESTART=false
