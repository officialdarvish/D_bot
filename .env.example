# Telegram
BOT_TOKEN=123456:ABC
ADMIN_IDS=123456789
OWNER_IDS=123456789
SELLER_IDS=

# Database / Redis
POSTGRES_DB=d_bot
POSTGRES_USER=dbot
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://dbot:change_me@db:5432/d_bot
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Security
FERNET_KEY=

# Bot settings
DEFAULT_CHANNEL_URL=https://t.me/example
PAYG_MIN_BALANCE_IRT=300000
PAYG_SCAN_MINUTES=60
TZ=Asia/Tehran

# Install chart start date shown in docs/install_chart.svg
PROJECT_GITHUB_ADDED_DATE=2026-06-21

# Docker image. Docker Hub requires lowercase repository names.
DOCKER_IMAGE=officialdarvish/d_bot:latest
PROJECT_GITHUB_ADDED_DATE=2026-06-21

# NOWPayments crypto gateway
NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=trx
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
# Example: https://your-domain.com/webhooks/nowpayments
NOWPAYMENTS_IPN_CALLBACK_URL=
