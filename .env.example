# Telegram
BOT_TOKEN=CHANGE_ME_BOT_TOKEN
ADMIN_IDS=123456789
OWNER_IDS=
SELLER_IDS=

# Database / Redis - Docker Compose values
POSTGRES_DB=d_bot
POSTGRES_USER=dbot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://dbot:CHANGE_ME_DB_PASSWORD@db:5432/d_bot
REDIS_URL=redis://redis:6379/0

# API / Admin panel

# Web admin credentials are printed by install.sh at the end of VPS installation.
# You can view initial credentials later with: dbot credentials
# If username/password are changed from Settings > Website & SSL, the website logs out automatically.
API_HOST=0.0.0.0
API_PORT=8000
WEB_ADMIN_USERNAME=CHANGE_ME_ADMIN_USER
WEB_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
DOMAIN_NAME=example.com
LETSENCRYPT_EMAIL=

# Security
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
BACKUP_SIGNING_SECRET=
BACKUP_REQUIRE_SIGNATURE=true
BACKUP_MAX_UPLOAD_BYTES=5242880
ADMIN_MAX_LOGIN_ATTEMPTS=8
ADMIN_LOGIN_LOCK_SECONDS=900
XUI_VERIFY_TLS=true
XUI_CA_BUNDLE=
DBOT_ALLOW_DOCKER_RESTART=false

# Bot settings
DEFAULT_CHANNEL_URL=https://t.me/officialdarvishchannel
PAYG_MIN_BALANCE_IRT=300000
PAYG_SCAN_MINUTES=60
TZ=Asia/Tehran
SERVER_SYNC_SECONDS=600

# NOWPayments / Crypto payment
NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=trx
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_IPN_CALLBACK_URL=

# Custom Panel / MikroTik PPP Panel
# The Custom Panel API requires X-API-Key / Bearer auth for /api/routers.
# Do not put real credentials in source. Set CUSTOM_PANEL_API_KEY in your private .env,
# or mount the panel config.json read-only so D BOT can read api_key automatically.
CUSTOM_PANEL_API_KEY=
MIKROTIK_PANEL_API_KEY=
CUSTOM_PANEL_CONFIG_PATH=/host/opt/mikrotik-panel/config.json
