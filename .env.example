# D Bot environment example
# Copy this file to .env and replace CHANGE_ME values before manual deployment.

BOT_TOKEN=CHANGE_ME_BOT_TOKEN
ADMIN_IDS=123456789
OWNER_IDS=
SELLER_IDS=

POSTGRES_DB=d_bot
POSTGRES_USER=dbot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dbot:CHANGE_ME_DB_PASSWORD@db:5432/d_bot

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

API_HOST=0.0.0.0
API_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
TZ=Asia/Tehran

WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
FERNET_KEY=CHANGE_ME_FERNET_KEY
JWT_SECRET=CHANGE_ME_JWT_SECRET

DEFAULT_CHANNEL_URL=https://t.me/example
SERVER_SYNC_SECONDS=5
PAYG_MIN_BALANCE_IRT=300000
PAYG_SCAN_MINUTES=60

NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=trx
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_IPN_CALLBACK_URL=

XUI_VERIFY_TLS=true
XUI_CA_BUNDLE=
BACKUP_REQUIRE_SIGNATURE=true
BACKUP_SIGNING_SECRET=
DBOT_ALLOW_DOCKER_RESTART=false

DOMAIN_NAME=example.com
ENABLE_HTTPS=true
LETSENCRYPT_EMAIL=
